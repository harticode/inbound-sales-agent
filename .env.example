# Required — choose a long random secret for API authentication
API_KEY=change-me-to-a-long-random-secret

# Required — FMCSA SAFER API key (https://mobile.fmcsa.dot.gov/qc/services)
FMCSA_API_KEY=

# Required for dashboard web calls — from platform.happyrobot.ai → Settings → API Keys
HAPPYROBOT_API_KEY=

# Required for dashboard web calls — workflow ID from the HappyRobot editor URL
HAPPYROBOT_WORKFLOW_ID=

# Postgres connection (docker-compose sets this automatically for the app service)
DATABASE_URL=postgresql://carrier:carrier@localhost:5432/carrier_sales

# Comma-separated origins allowed for dashboard API access without X-API-Key
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# Public dashboard URL (update after cloud deploy)
DASHBOARD_URL=http://localhost

# HappyRobot environment: production | development
HAPPYROBOT_ENV=development

# Negotiation defaults (overridable at runtime via Settings page)
NEGOTIATION_MAX_ROUNDS=3
NEGOTIATION_MIN_MARGIN_PCT=0.05
OFFER_RATE_PCT=0.85

# FMCSA carrier cache TTL in hours
CARRIER_CACHE_TTL_HOURS=24

# Agent ROI assumptions for dashboard
AGENT_AVG_HUMAN_HANDLE_MINUTES=8.0
AGENT_AVG_HUMAN_COST_PER_CALL=12.50
